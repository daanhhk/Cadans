{
  "name": "@cadans/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "typecheck": "tsc --noEmit",
    "deploy": "wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply cadans --local",
    "db:verify:local": "wrangler d1 execute cadans --local --command \"SELECT name FROM sqlite_master WHERE type='table' ORDER BY name\""
  },
  "dependencies": {
    "@cadans/engine": "workspace:*",
    "@cadans/shared": "workspace:*",
    "drizzle-orm": "^0.38.0",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.71",
    "@cloudflare/workers-types": "^4.20241127.0",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.6.0",
    "wrangler": "^4.0.0"
  }
}
